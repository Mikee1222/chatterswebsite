# =============================================================================
# Chatter Dashboard – Production environment variables
# Copy to .env and set real values. Never commit .env or real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Airtable (required)
# -----------------------------------------------------------------------------
AIRTABLE_TOKEN=YOUR_AIRTABLE_API_KEY
AIRTABLE_BASE_ID=YOUR_AIRTABLE_BASE_ID

# -----------------------------------------------------------------------------
# Session / Auth (required in production)
# -----------------------------------------------------------------------------
# Min 32 characters for HS256. Generate: openssl rand -base64 32
SESSION_JWT_SECRET=YOUR_SESSION_SECRET_MIN_32_CHARS

# -----------------------------------------------------------------------------
# Demo login (optional – fallback when no Airtable user matches)
# -----------------------------------------------------------------------------
DEMO_LOGIN_EMAIL=admin@example.com
DEMO_LOGIN_PASSWORD=demo123
DEMO_LOGIN_ROLE=admin

# -----------------------------------------------------------------------------
# App URL (optional but recommended for production – PWA manifest, push, links)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-app.pages.dev

# -----------------------------------------------------------------------------
# Web Push / VAPID (optional – for push notifications)
# Generate: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# -----------------------------------------------------------------------------
# Admin notifications (optional – comma-separated Airtable user record IDs)
# Used to notify admins for whale/custom events.
# -----------------------------------------------------------------------------
# ADMIN_AIRTABLE_USER_IDS=recXXX,recYYY

# -----------------------------------------------------------------------------
# Realtime (optional – WebSocket + Durable Object)
# Deploy realtime Worker separately; then set:
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_REALTIME_WS_URL=wss://chatter-realtime.<subdomain>.workers.dev/realtime
# REALTIME_BROADCAST_URL=https://chatter-realtime.<subdomain>.workers.dev
# REALTIME_BROADCAST_SECRET=YOUR_REALTIME_SECRET
# REALTIME_JWT_SECRET=YOUR_REALTIME_JWT_SECRET_MIN_32_CHARS

# -----------------------------------------------------------------------------
# Cloudflare D1 (optional – production auth backend)
# When using D1, bind in wrangler.toml and set:
# -----------------------------------------------------------------------------
# D1_DATABASE_ID=your_d1_database_id
