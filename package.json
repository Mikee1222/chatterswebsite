{
  "name": "chatter-dashboard",
  "version": "1.0.0",
  "description": "Internal dashboard – Airtable backend, Cloudflare deploy",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "setup:airtable": "tsx scripts/setup-airtable.ts",
    "verify:airtable": "tsx scripts/setup-airtable.ts --verify-only",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute chatter-d1 --remote --file=./drizzle/migrations/0000_initial.sql",
    "db:studio": "wrizzle-kit studio",
    "pages:build": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dotenv": "^16.3.1",
    "jose": "^6.2.0",
    "lucide-react": "^0.294.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0-beta.19",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.16",
    "drizzle-kit": "^0.20.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.99.0"
  }
}
